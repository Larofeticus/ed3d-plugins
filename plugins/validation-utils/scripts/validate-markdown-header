#!/usr/bin/env bash
set -euo pipefail

# validate-markdown-header: Check if specific markdown header exists
#
# Usage:
#   validate-markdown-header --header "## Title" [--json] FILE
#
# Exit codes:
#   0 - header found
#   1 - header not found
#   2 - invalid usage

error_exit() {
    local message="$1"
    local exit_code="${2:-1}"
    echo "ERROR: ${message}" >&2
    exit "${exit_code}"
}

json_output=false
header=""

while getopts ":H:jh-:" opt; do
    case "$opt" in
        H) header="$OPTARG" ;;
        j) json_output=true ;;
        h)
            cat <<EOF
Usage: validate-markdown-header --header "## Title" [OPTIONS] FILE

Check if a specific markdown header exists in the file.

OPTIONS:
  -H, --header HEADER   Header to search for (required)
  --json                Output JSON: {"valid": true/false, "message": "...", "error": "..."}
  -h                    Show this help (note: use -H for header argument)

EXIT CODES:
  0 - Header found
  1 - Header not found or file error
  2 - Invalid arguments

EXAMPLES:
  validate-markdown-header -H "## Installation" README.md
  validate-markdown-header --header "### Configuration" --json doc.md
EOF
            exit 0
            ;;
        -)
            case "$OPTARG" in
                header=*) header="${OPTARG#*=}" ;;
                json) json_output=true ;;
                *) error_exit "Unknown option --${OPTARG}" 2 ;;
            esac
            ;;
        :) error_exit "Option -${OPTARG} requires an argument" 2 ;;
        \?) error_exit "Invalid option: -${OPTARG}" 2 ;;
    esac
done

shift $((OPTIND - 1))

[[ -z "$header" ]] && error_exit "Header required (use -H or --header)" 2
[[ $# -eq 0 ]] && error_exit "FILE argument required" 2
[[ $# -gt 1 ]] && error_exit "Too many arguments (expected one FILE)" 2

FILE="$1"

[[ ! -f "$FILE" ]] && error_exit "File not found: ${FILE}" 1

# Check dependencies
command -v grep >/dev/null 2>&1 || error_exit "grep not found (required dependency)" 1

# Search for header (grep -q exits with 0 if found, 1 if not found)
if grep -q "^${header}$" "$FILE"; then
    if $json_output; then
        echo '{"valid": true, "message": "Header found"}'
    else
        echo "VALID"
    fi
    exit 0
else
    if $json_output; then
        echo '{"valid": false, "message": "Header not found", "error": "'"${header}"' does not exist in '"${FILE}"'"}'
        exit 1
    else
        error_exit "Header not found: ${header}" 1
    fi
fi
